---
interface Props {
  id: string;
  title: string;
  summary: string;
  chips: { text: string; outcome?: boolean }[];
  disabled?: boolean;
}
const { id, title, summary, chips, disabled = false } = Astro.props;
---
<div class:list={["bg-surface p-8 transition-colors border-b border-border-dim last:border-b-0 group", disabled ? "opacity-50 cursor-default" : "hover:bg-surface-2 cursor-pointer"]}>
  <div class="font-mono text-[9px] text-text-muted tracking-[0.1em] uppercase mb-2">
    {id}
  </div>
  <div class="flex items-start justify-between gap-5 mb-3">
    <h3 class="text-[17px] font-medium text-text-main leading-tight max-w-[520px]">
      {title}
    </h3>
    { !disabled && (
      <span class="text-lg text-text-muted group-hover:text-accent group-hover:translate-x-1 transition-all">→</span>
    )}
  </div>
  <p class="text-[13px] text-text-dim max-w-[600px] leading-relaxed mb-4">
    {summary}
  </p>
  <div class="flex flex-wrap gap-1.5">
    {chips.map(chip => (
      <span class:list={["font-mono text-[9px] px-2 py-0.5 rounded-[2px] tracking-wide uppercase border", chip.outcome ? "border-accent-dim text-accent" : "border-border-bright text-text-muted"]}>
        {chip.text}
      </span>
    ))}
  </div>
</div>
