---
interface Props {
  id: string;
  title: string;
  summary: string;
  chips: { text: string; outcome?: boolean }[];
  disabled?: boolean;
  href?: string;
}
const { id, title, summary, chips, disabled = false, href } = Astro.props;
const resolvedHref = href ? import.meta.env.BASE_URL.replace(/\/$/, '') + href : undefined;
const Tag = resolvedHref && !disabled ? 'a' : 'div';
---
<Tag href={resolvedHref} class:list={["block bg-background-secondary p-8 transition-colors border-b border-border-subtle last:border-b-0 group", disabled ? "opacity-50 cursor-default" : "hover:bg-background-tertiary cursor-pointer"]}>
  <div class="font-mono text-xs text-content-muted tracking-widest uppercase mb-2">
    {id}
  </div>
  <div class="flex items-start justify-between gap-5 mb-4">
    <h3 class="text-xl font-medium text-content-primary leading-tight max-w-[520px]">
      {title}
    </h3>
    { !disabled && (
      <span class="text-xl text-content-muted group-hover:text-accent group-hover:translate-x-1 transition-all">→</span>
    )}
  </div>
  <p class="text-sm text-content-secondary max-w-[600px] leading-relaxed mb-5">
    {summary}
  </p>
  <div class="flex flex-wrap gap-2">
    {chips.map(chip => (
      <span class:list={["font-mono text-xs px-2.5 py-1 rounded-sm tracking-wide uppercase border", chip.outcome ? "border-accent-muted text-accent" : "border-border-default text-content-muted"]}>
        {chip.text}
      </span>
    ))}
  </div>
</Tag>

