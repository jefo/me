---
interface Props {
  label: string;
  title: string;
  description: string;
}
const { label, title, description } = Astro.props;
---
<div class="p-5 bg-background-secondary border border-border-subtle rounded-md">
  <div class="font-mono text-[9px] text-accent tracking-[0.1em] uppercase mb-2">{label}</div>
  <div class="text-sm font-medium text-content-primary mb-1.5">{title}</div>
  <div class="text-[13px] text-content-secondary leading-relaxed">{description}</div>
</div>
