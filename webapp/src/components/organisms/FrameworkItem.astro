---
interface Props {
  name: string;
  status: string;
  description: string;
  principles: string[];
}
const { name, status, description, principles } = Astro.props;
---
<div class="bg-background-secondary p-8 grid grid-cols-1 md:grid-cols-[200px_1fr] gap-4 md:gap-10 items-start transition-colors hover:bg-background-tertiary border-b border-border-subtle last:border-b-0 group">
  <div>
    <div class="text-base font-medium text-content-primary mb-1 group-hover:text-accent transition-colors">{name}</div>
    <div class="font-mono text-xs text-content-muted tracking-wide uppercase">{status}</div>
  </div>
  <div>
    <p class="text-sm text-content-secondary leading-relaxed mb-4">
      {description}
    </p>
    <div class="flex flex-wrap gap-2">
      {principles.map(p => (
        <span class="font-mono text-xs px-2.5 py-1 rounded-sm tracking-wide uppercase border border-border-default text-content-muted">
          {p}
        </span>
      ))}
    </div>
  </div>
</div>

