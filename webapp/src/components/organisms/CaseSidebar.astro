---
import TocLink from '../molecules/TocLink.astro';
import MetaRow from '../molecules/MetaRow.astro';
import StatusDot from '../atoms/StatusDot.svelte';

interface Props {
  caseId: string;
  title: string;
  status: string;
  toc: { href: string; text: string }[];
  meta: { label: string; value: string; accent?: boolean }[];
}
const { caseId, title, status, toc, meta } = Astro.props;
---
<aside class="w-full lg:w-rail flex-shrink-0 p-10 lg:px-7 lg:py-10 border-b lg:border-b-0 lg:border-r border-border-subtle sticky top-0 h-auto lg:h-screen overflow-y-auto flex flex-col gap-6 bg-background-primary z-50">
  <a href="/" class="font-mono text-[10px] text-content-muted flex items-center gap-1.5 tracking-wide hover:text-accent transition-colors">
    ← Systems
  </a>

  <div class="h-px bg-border-subtle"></div>

  <div>
    <div class="font-mono text-[9px] text-content-muted tracking-[0.12em] uppercase">{caseId}</div>
    <div class="text-[13px] font-medium text-content-primary mt-1.5 leading-snug">{title}</div>
    <div class="mt-2">
      <StatusDot text={status} client:load />
    </div>
  </div>

  <div class="h-px bg-border-subtle"></div>

  <nav class="flex flex-col gap-0.5">
    <div class="font-mono text-[9px] text-content-muted tracking-[0.1em] uppercase mb-1.5">Contents</div>
    {toc.map(item => <TocLink href={item.href} text={item.text} />)}
  </nav>

  <div class="h-px bg-border-subtle"></div>

  <div class="flex flex-col gap-2.5">
    {meta.map(item => <MetaRow label={item.label} value={item.value} accent={item.accent} />)}
  </div>

  <div class="flex flex-col gap-0.5 mt-auto">
    <a href="#" class="font-mono text-[10px] text-content-muted flex items-center gap-1.5 hover:text-accent transition-colors">
      <span class="opacity-40">↗</span> View on GitHub
    </a>
    <a href="#" class="font-mono text-[10px] text-content-muted flex items-center gap-1.5 hover:text-accent transition-colors">
      <span class="opacity-40">↗</span> Read Case Study PDF
    </a>
  </div>
</aside>
