---
import StatusDot from "../atoms/StatusDot.svelte";
import NavLink from "../molecules/NavLink.svelte";
---
<aside class="w-full lg:w-rail flex-shrink-0 p-10 lg:px-8 lg:py-10 border-b lg:border-b-0 lg:border-r border-border-subtle sticky top-0 h-auto lg:h-screen overflow-y-auto flex flex-col gap-10 bg-background-primary z-50">
  <div>
    <div class="text-base font-medium tracking-tight text-content-primary">Alex Mercer</div>
    <div class="font-mono text-xs text-content-muted mt-2 leading-relaxed">
      Systems Architect<br />
      DDD / AI Systems / Knowledge Engineering
    </div>
  </div>

  <div class="hidden lg:block">
    <StatusDot client:load />
  </div>

  <div class="hidden lg:block h-px bg-border-subtle"></div>

  <nav class="flex flex-row lg:flex-col flex-wrap gap-1 lg:gap-0.5">
    <NavLink href="#systems" active>Systems</NavLink>
    <NavLink href="#cases">Case Studies</NavLink>
    <NavLink href="#research">Research</NavLink>
    <NavLink href="#frameworks">Frameworks</NavLink>
    <NavLink href="#writing">Writing</NavLink>
    <NavLink href="#about">About</NavLink>
  </nav>

  <div class="hidden lg:block h-px bg-border-subtle"></div>

  <div class="flex flex-row lg:flex-col flex-wrap gap-6 lg:gap-1.5 mt-auto">
    <a href="#" class="font-mono text-xs text-content-muted flex items-center gap-2 hover:text-accent group transition-colors">
      <span class="opacity-40 group-hover:opacity-100 transition-opacity">↗</span> GitHub
    </a>
    <a href="#" class="font-mono text-xs text-content-muted flex items-center gap-2 hover:text-accent group transition-colors">
      <span class="opacity-40 group-hover:opacity-100 transition-opacity">↗</span> Telegram
    </a>
    <a href="#" class="font-mono text-xs text-content-muted flex items-center gap-2 hover:text-accent group transition-colors">
      <span class="opacity-40 group-hover:opacity-100 transition-opacity">↗</span> LinkedIn
    </a>
    <a href="#" class="font-mono text-xs text-content-muted flex items-center gap-2 hover:text-accent group transition-colors">
      <span class="opacity-40 group-hover:opacity-100 transition-opacity">↗</span> Email
    </a>
  </div>
</aside>

