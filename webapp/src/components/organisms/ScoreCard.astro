---
interface Props {
  name: string;
  type: string;
  score: number;
  total: number;
  color: string;
  barColor: string;
  note: string;
  featured?: boolean;
}
const { name, type, score, total, color, barColor, note, featured = false } = Astro.props;
---
<div class:list={["bg-background-secondary p-6", featured && "bg-background-tertiary border-l-2 border-l-accent"]}>
  <div class="text-sm font-medium text-content-primary mb-1">{name}</div>
  <div class="font-mono text-[9px] text-content-muted tracking-[0.06em] uppercase mb-4">{type}</div>
  <div class="flex items-baseline gap-1.5 mb-3">
    <span class:list={["font-mono text-[28px] font-medium leading-none", color]}>{score}</span>
    <span class="font-mono text-[13px] text-content-muted">/ {total}</span>
  </div>
  <div class="bg-border-subtle rounded-sm h-[3px] mb-4 overflow-hidden">
    <div class:list={["h-full rounded-sm transition-all duration-500", barColor]} style={`width: ${(score / total) * 100}%`}></div>
  </div>
  <div class="text-[12px] text-content-muted leading-relaxed" set:html={note} />
</div>
