---
interface Props {
  type: string;
  status: 'active' | 'research' | 'complete';
  statusText: string;
  title: string;
  description: string;
  stack: string;
}
const { type, status, statusText, title, description, stack } = Astro.props;

const statusClasses = {
  active: "bg-accent-dim text-accent",
  research: "bg-[#2A2010] text-[#EF9F27]",
  complete: "bg-[#0F2A1A] text-[#5DCAA5]",
};
---
<div class="bg-surface p-7 transition-colors hover:bg-surface-2 cursor-pointer flex flex-col gap-3 group">
  <div class="flex items-center justify-between">
    <span class="font-mono text-[9px] text-text-muted tracking-[0.1em] uppercase">
      {type}
    </span>
    <span class:list={["font-mono text-[9px] px-2 py-0.5 rounded-[2px] tracking-wide uppercase", statusClasses[status]]}>
      {statusText}
    </span>
  </div>
  <div class="text-base font-medium text-text-main leading-snug group-hover:text-accent transition-colors">
    {title}
  </div>
  <p class="text-[13px] text-text-dim leading-relaxed flex-1">
    {description}
  </p>
  <div class="font-mono text-[10px] text-text-muted pt-3 border-t border-border-dim">
    {stack}
  </div>
</div>
