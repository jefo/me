---
interface Props {
  type: string;
  status: 'active' | 'research' | 'complete';
  statusText: string;
  title: string;
  description: string;
  stack: string;
}
const { type, status, statusText, title, description, stack } = Astro.props;

const statusClasses = {
  active: "bg-accent-muted text-accent",
  research: "bg-[#2A2010] text-[#EF9F27]",
  complete: "bg-[#0F2A1A] text-[#5DCAA5]",
};
---
<div class="bg-background-secondary p-8 transition-colors hover:bg-background-tertiary cursor-pointer flex flex-col gap-4 group">
  <div class="flex items-center justify-between">
    <span class="font-mono text-xs text-content-muted tracking-widest uppercase">
      {type}
    </span>
    <span class:list={["font-mono text-[10px] px-2 py-0.5 rounded-sm tracking-wide uppercase", statusClasses[status]]}>
      {statusText}
    </span>
  </div>
  <div class="text-lg font-medium text-content-primary leading-snug group-hover:text-accent transition-colors">
    {title}
  </div>
  <p class="text-sm text-content-secondary leading-relaxed flex-1">
    {description}
  </p>
  <div class="font-mono text-xs text-content-muted pt-4 border-t border-border-subtle">
    {stack}
  </div>
</div>

