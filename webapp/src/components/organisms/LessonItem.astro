---
interface Props {
  num: string;
  title: string;
  body: string;
}
const { num, title, body } = Astro.props;
---
<div class="bg-background-secondary px-7 py-6 grid grid-cols-1 md:grid-cols-[60px_1fr] gap-5 items-start transition-colors hover:bg-background-tertiary">
  <div class="hidden md:block font-mono text-[22px] font-medium text-border-default leading-none pt-0.5">{num}</div>
  <div>
    <div class="text-sm font-medium text-content-primary mb-1.5">{title}</div>
    <div class="text-[13px] text-content-secondary leading-relaxed">{body}</div>
  </div>
</div>
