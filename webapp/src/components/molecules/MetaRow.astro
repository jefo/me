---
interface Props {
  label: string;
  value: string;
  accent?: boolean;
}
const { label, value, accent = false } = Astro.props;
---
<div class="flex flex-col gap-0.5">
  <span class="font-mono text-[9px] text-content-muted tracking-[0.08em] uppercase">{label}</span>
  <span class:list={["font-mono text-[11px]", accent ? "text-green" : "text-content-secondary"]}>{value}</span>
</div>
