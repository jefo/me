---
interface Props {
  value: string;
  label: string;
}
const { value, label } = Astro.props;
---
<div class="bg-background-secondary p-6 text-left border-border-subtle">
  <div class="font-mono text-2xl font-medium text-content-primary mb-1.5 leading-none">
    {value}
  </div>
  <div class="font-mono text-xs text-content-muted tracking-wide uppercase">
    {label}
  </div>
</div>

