---
interface Props {
  category: string;
  title: string;
  date: string;
}
const { category, title, date } = Astro.props;
---
<div class="grid grid-cols-[80px_1fr] md:grid-cols-[100px_1fr_80px] gap-6 items-baseline py-3.5 border-b border-border-dim transition-colors hover:bg-surface/30 group">
  <span class="font-mono text-[9px] text-accent tracking-wider uppercase">
    {category}
  </span>
  <span class="text-sm text-text-dim transition-colors group-hover:text-text-main">
    {title}
  </span>
  <span class="hidden md:block font-mono text-[10px] text-text-muted text-right">
    {date}
  </span>
</div>
