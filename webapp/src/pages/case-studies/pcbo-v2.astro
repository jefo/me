  <script>
    // Toggle buttons (terminal/cards, table/scores)
    document.querySelectorAll('.toggle-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const group = btn.getAttribute('data-group');
        const target = btn.getAttribute('data-target');

        // Update button states
        btn.closest('.flex')?.querySelectorAll('.toggle-btn').forEach(b => {
          b.classList.remove('text-accent', 'bg-background-tertiary');
          b.classList.add('text-content-muted');
        });
        btn.classList.add('text-accent', 'bg-background-tertiary');
        btn.classList.remove('text-content-muted');

        // Show/hide panels
        if (group === 'artifact') {
          document.getElementById('artifact-terminal')!.classList.toggle('hidden', target !== 'terminal');
          document.getElementById('artifact-cards')!.classList.toggle('hidden', target !== 'cards');
        } else if (group === 'bench') {
          document.getElementById('bench-table')!.classList.toggle('hidden', target !== 'table');
          document.getElementById('bench-scores')!.classList.toggle('hidden', target !== 'scores');
        }
      });
    });

    // TOC active state on scroll
    const tocLinks = document.querySelectorAll('.toc-link');
    const sections = document.querySelectorAll('section[id]');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(a => {
            a.classList.remove('text-accent', 'bg-background-secondary');
            a.classList.add('text-content-muted');
          });
          const active = document.querySelector(`.toc-link[href="#${entry.target.id}"]`);
          if (active) {
            active.classList.add('text-accent', 'bg-background-secondary');
            active.classList.remove('text-content-muted');
          }
        }
      });
    }, { rootMargin: '-30% 0px -60% 0px' });

    sections.forEach(s => observer.observe(s));
  </script>
</Layout>
